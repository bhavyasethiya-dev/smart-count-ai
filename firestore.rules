rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidScan(data) {
      return data.totalItems is number && 
             data.imageUrl is string && 
             data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /scans/{scanId} {
      allow create: if isSignedIn() && isValidId(scanId) && isValidScan(request.resource.data);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(scanId) && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(scanId) && resource.data.userId == request.auth.uid;
    }

    match /settings/{userId} {
      allow read, write: if isValidId(userId) && isOwner(userId);
    }
  }
}
